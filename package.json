{
  "name": "pl-translate-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "css:build": "npm run css:build --workspace pl-review-desktop",
    "start": "npm run start --workspace pl-review-desktop",
    "dev": "npm run dev --workspace pl-review-desktop",
    "sidecar": "npm run start --workspace pl-puppeteer-sidecar --",
    "sidecar:check": "npm run check --workspace pl-puppeteer-sidecar"
  },
  "engines": {
    "node": ">=20"
  }
}
